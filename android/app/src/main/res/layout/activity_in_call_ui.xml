<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_incall_screen"
    android:padding="18dp">

    <TextureView
        android:id="@+id/remoteVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000" />

    <FrameLayout
        android:id="@+id/previewVideoContainer"
        android:layout_width="112dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="10dp"
        android:background="#991A2238"
        android:elevation="6dp"
        android:visibility="gone">

        <TextureView
            android:id="@+id/previewVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="74dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/callName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact"
            android:textColor="#F3F6FF"
            android:textSize="44sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/callNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#D1D9EA"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/callStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Calling..."
            android:textColor="#D7DEEC"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="34dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- TOP ROW: Add | Bluetooth | Hold — hidden when keypad is open -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/addCallControl"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/addCallButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_incall_action_neutral"
                    android:contentDescription="Add call"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_input_add"
                    android:tint="#E8EEF9" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Add call"
                    android:textColor="#D7DEEC"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bluetoothControl"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/bluetoothButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_incall_action_neutral"
                    android:contentDescription="Bluetooth"
                    android:padding="14dp"
                    android:src="@android:drawable/stat_sys_data_bluetooth"
                    app:tint="@color/incall_toggle_icon_tint" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Bluetooth"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/holdControl"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/holdButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_incall_action_neutral"
                    android:contentDescription="Hold"
                    android:padding="14dp"
                    android:src="@drawable/ic_hold_pause_simple"
                    app:tint="@color/incall_toggle_icon_tint" />
                <TextView
                    android:id="@+id/holdLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Hold"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- KEYPAD PANEL (shown when keypad toggled) -->
        <include layout="@layout/incall_keypad_panel" />

        <!-- INCOMING CALL DETAILS + QUICK REPLIES -->
        <include layout="@layout/incall_incoming_panel" />

        <!-- BOTTOM ROW: Speaker | Keypad | Mute — always visible -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/speakerControl"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/speakerButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_incall_action_neutral"
                    android:contentDescription="Speaker"
                    android:padding="14dp"
                    android:src="@drawable/ic_speaker_standard"
                    app:tint="@color/incall_toggle_icon_tint" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Speaker"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/keypadControl"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/keypadButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_incall_action_neutral"
                    android:contentDescription="Keypad"
                    android:padding="14dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_keypad_clean"
                    app:tint="@color/incall_toggle_icon_tint" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Keypad"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/muteControl"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/muteButton"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:background="@drawable/bg_incall_action_neutral"
                    android:contentDescription="Mute"
                    android:padding="14dp"
                    android:src="@drawable/ic_custom_mic_off"
                    app:tint="@color/incall_toggle_icon_tint" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Mute"
                    android:textColor="#D7DEEC"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- END / ANSWER BUTTONS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/answerButton"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_marginEnd="48dp"
                android:background="@drawable/bg_incall_circle_green"
                android:contentDescription="Answer"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/endButton"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:background="@drawable/bg_incall_circle_red"
                android:contentDescription="End"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_end_call_sized_25"
                android:tint="@null" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
