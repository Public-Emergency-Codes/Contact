{
  "name": "contact",
  "version": "1.0.0",
  "description": "An Android phone app that enhances the calling and messaging you already use every day with built-in emergency tools — silent text-to-911, video dispatch, live location, medical-data relay, and routing to 988, 311, and 211. No new workflows to learn.",
  "license": "0BSD",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit --allowJs false --noUnusedLocals --noUnusedParameters",
    "test": "node --no-warnings --experimental-strip-types --test tests/*.test.mjs",
    "licenses": "node scripts/audit-licenses.js",
    "public-check": "node scripts/check-public-repo.js",
    "android:verify-native": "node scripts/verify-native-android.js",
    "android:bundle:play": "node scripts/build-play-bundle.js",
    "audit": "npm audit --audit-level=high",
    "check": "npm run typecheck && npm run lint && npm run test && npm run licenses && npm run public-check && npm run android:verify-native",
    "android:compile": "cd android && gradlew.bat :app:compileDebugKotlin --no-daemon",
    "ios": "expo run:ios"
  },
  "keywords": [
    "android",
    "expo",
    "react-native",
    "emergency",
    "911",
    "988",
    "311",
    "211",
    "phone",
    "calling",
    "sms",
    "public-safety"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/native": "^7.1.27",
    "@react-navigation/stack": "^7.6.14",
    "@reduxjs/toolkit": "^2.11.2",
    "expo": "^57.0.1",
    "expo-contacts": "~57.0.0",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-intent-launcher": "~57.0.0",
    "expo-keep-awake": "~57.0.0",
    "expo-linking": "^57.0.1",
    "expo-location": "~57.0.2",
    "expo-media-library": "~57.0.0",
    "expo-modules-autolinking": "~57.0.0",
    "expo-modules-core": "~57.0.1",
    "expo-notifications": "^57.0.2",
    "expo-task-manager": "~57.0.1",
    "expo-video": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-permissions": "^5.4.4",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-vision-camera": "^4.7.3",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "react-native-worklets-core": "^1.4.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.4",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "private": true
}
