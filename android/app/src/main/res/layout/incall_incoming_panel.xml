<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/incomingExtrasPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="28dp"
    android:orientation="vertical"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/lastCallCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_incall_info_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last call"
            android:textColor="#D7DEEC"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/lastCallText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#F3F6FF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/recentSmsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_incall_info_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Most recent SMS"
            android:textColor="#D7DEEC"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/recentSmsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#F3F6FF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/openQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_incall_info_card"
        android:gravity="center"
        android:padding="14dp"
        android:text="Quick response"
        android:textColor="#F3F6FF"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
